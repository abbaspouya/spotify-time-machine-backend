SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback
FRONTEND_URL=http://127.0.0.1:5173

# Optional frontend callback route
# FRONTEND_AUTH_CALLBACK_PATH=/auth/callback

# Optional CORS override
# CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Session cookie defaults for local development
# SESSION_COOKIE_NAME=spotify_time_machine_session
# SESSION_COOKIE_DOMAIN=
# SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_MAX_AGE_SECONDS=2592000

# Async job retention
# JOB_RETENTION_SECONDS=21600

# Logging
# LOG_LEVEL=INFO
